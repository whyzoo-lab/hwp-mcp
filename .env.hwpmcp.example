# 복사: cp .env.hwpmcp.example .env.hwpmcp  (그리고 시크릿을 실제 값으로 교체; .env.hwpmcp는 커밋 금지)
POSTGRES_USER=rhwp
POSTGRES_PASSWORD=__STRONG_DB_PASSWORD__
POSTGRES_DB=rhwp
MINIO_ROOT_USER=rhwpminio
MINIO_ROOT_PASSWORD=__STRONG_MINIO_PASSWORD__

# 앱이 내부 네트워크로 db/minio에 접속(compose 서비스명 사용)
RHWP_DATABASE_URL=postgres://rhwp:__STRONG_DB_PASSWORD__@hwpmcp-db:5432/rhwp
RHWP_S3_ENDPOINT=http://hwpmcp-minio:9000
RHWP_S3_REGION=us-east-1
RHWP_S3_BUCKET=rhwp-docs
RHWP_S3_ACCESS_KEY=rhwpminio
RHWP_S3_SECRET_KEY=__STRONG_MINIO_PASSWORD__
RHWP_S3_PATH_STYLE=true
RHWP_COOKIE_SECURE=true
# 인증 요구 여부. 기본 true(멀티유저 호스팅, 베어러/OAuth 필요).
# false 로 두면 인증 없이 단일 로컬 사용자로 동작(자가호스팅/신뢰망 전용).
# 공개 인터넷에 노출된 서버에서는 절대 false 로 두지 마세요.
RHWP_AUTH_REQUIRED=true
